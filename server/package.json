{
  "name": "noodla-server",
  "version": "1.0.0",
  "description": "Noodla API Server",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.3.0",
    "@types/ws": "^8.18.1",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.39.3",
    "hono": "^4.7.5",
    "jose": "^5.10.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.1.0",
    "ws": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "vitest": {
    "include": [
      "tests/**/*.test.ts"
    ],
    "environment": "node"
  }
}
